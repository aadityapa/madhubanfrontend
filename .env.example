# API origin (no trailing slash). Requests go to ${VITE_API_BASE_URL}/api/...
# Local: http://localhost:3000
# Production example: https://nexyyra.com
VITE_API_BASE_URL=https://nexyyra.com

# Optional demo token when backend returns 404 in non-production
VITE_DEV_TOKEN=

# Mobile (Expo) — same variable semantics as web
EXPO_PUBLIC_API_BASE_URL=https://nexyyra.com
