# Web (Vite) — optional override; leave unset in dev to use Vite proxy + relative /api
VITE_API_BASE_URL=

# Optional demo token when backend returns 404 in non-production
VITE_DEV_TOKEN=

# Mobile (Expo) — full backend URL for device/simulator (defaults in app if unset)
EXPO_PUBLIC_API_BASE_URL=https://madhuban360-backend.onrender.com
