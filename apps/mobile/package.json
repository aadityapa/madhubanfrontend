{
  "name": "@madhuban/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "node ./scripts/expo-start.js",
    "start": "node ./scripts/expo-start.js",
    "android": "node ./scripts/expo-start.js --android",
    "ios": "node ./scripts/expo-start.js --ios",
    "web": "node ./scripts/expo-start.js --web",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "eas:apk": "eas build --platform android --profile preview",
    "eas:apk:local": "eas build --platform android --profile preview --local",
    "eas:dev": "eas build --platform android --profile development"
  },
  "dependencies": {
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@madhuban/api": "workspace:*",
    "@madhuban/theme": "workspace:*",
    "@madhuban/types": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "^31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "^1.5.3",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
